# Copy to .env and fill in values

# Database (local without Docker)
DATABASE_URL=postgresql+asyncpg://drivermap:drivermap@localhost:5432/drivermap
DATABASE_URL_SYNC=postgresql://drivermap:drivermap@localhost:5432/drivermap

# Auth
JWT_SECRET=change-me-in-production

# Google Maps Platform — enable Directions, Maps JavaScript, Places, Geocoding
# https://console.cloud.google.com/google/maps-apis
GOOGLE_MAPS_API_KEY=

# Frontend (Vite) — browser key, restrict HTTP referrers to your domain
VITE_GOOGLE_MAPS_API_KEY=
VITE_API_URL=http://localhost:8000

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
